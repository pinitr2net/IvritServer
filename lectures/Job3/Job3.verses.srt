00:10:09,260 --> 00:10:11,939
תִּתְקְפֵהוּ לָנֶצַח וַיַּהֲלֹךְ מְשַׁנֶּה פָנָיו וַתְּשַׁלְּחֵהוּ

87
00:10:11,940 --> 00:10:13,999
יִכְבְּדוּ בָנָיו וְלֹא יֵדָע וְיִצְעֲרוּ וְלֹא־יָבִין לָמוֹ

88
00:10:14,000 --> 00:10:30,999
אַךְ־בְּשָׂרוֹ עָלָיו יִכְאָב וְנַפְשׁוֹ עָלָיו תֶּאֱבָל

89
00:10:31,000 --> 00:10:32,659
אליפז בסבב השני

90
00:10:32,660 --> 00:10:34,959
וַיַּעַן אֱלִיפַז הַתֵּימָנִי וַיֹּאמַר

91
00:10:34,960 --> 00:10:42,479
הֶחָכָם יַעֲנֶה דַעַת־רוּחַ וִימַלֵּא קָדִים בִּטְנוֹ

92
00:10:42,480 --> 00:10:49,339
הוֹכֵחַ בְּדָבָר לֹא יִסְכּוֹן וּמִלִּים לֹא־יוֹעִיל בָּם

93
00:10:49,340 --> 00:10:53,799
אַף־אַתָּה תָּפֵר יִרְאָה וְתִגְרַע שִׂיחָה לִפְנֵי־אֵל

94
00:10:53,800 --> 00:10:59,299
כִּי יְאַלֵּף עֲוֺנְךָ פִיךָ וְתִבְחַר לְשׁוֹן עֲרוּמִים

95
00:10:59,300 --> 00:11:17,179
יַרְשִׁיעֲךָ פִיךָ וְלֹא־אָנִי וּשְׂפָתֶיךָ יַעֲנוּ־בָךְ

96
00:11:17,180 --> 00:11:22,659
הֲרִאישׁוֹן אָדָם תִּוָּלֵד וְלִפְנֵי גְבָעוֹת חוֹלָלְתָּ

97
00:11:22,660 --> 00:11:29,779
הַבְסוֹד אֱלוֹהַּ תִּשְׁמָע וְתִגְרַע אֵלֶיךָ חָכְמָה

98
00:11:29,780 --> 00:11:34,879
מַה־יָּדַעְתָּ וְלֹא נֵדָע תָּבִין וְלֹא־עִמָּנוּ הוּא

99
00:11:34,880 --> 00:11:41,739
גַּם־שָׂב גַּם־יָשִׁישׁ בָּנוּ כַּבִּיר מֵאָבִיךָ יָמִים

100
00:11:41,740 --> 00:11:46,599
הַמְעַט מִמְּךָ תַּנְחוּמוֹת אֵל וְדָבָר לָאַט עִמָּךְ

101
00:11:46,600 --> 00:11:50,319
מַה־יִּקָּחֲךָ לִבֶּךָ וּמַה־יִּרְזְמוּן עֵינֶיךָ

102
00:11:50,320 --> 00:11:56,439
כִּי־תָשִׁיב אֶל־אֵל רוּחֶךָ וְהֹצֵאתָ מִפִּיךָ מִלִּין

103
00:11:56,440 --> 00:12:05,259
מָה־אֱנוֹשׁ כִּי־יִזְכֶּה וְכִי־יִצְדַּק יְלוּד אִשָּׁה

104
00:12:05,260 --> 00:12:15,179
הֵן בִּקְדֹשָׁו לֹא יַאֲמִין וְשָׁמַיִם לֹא־זַכּוּ בְעֵינָיו

105
00:12:15,180 --> 00:12:20,439
אַף כִּי־נִתְעָב וְנֶאֱלָח אִישׁ־שֹׁתֶה כַמַּיִם עַוְלָה

106
00:12:20,440 --> 00:12:32,539
אֲחַוְךָ שְׁמַע־לִי וְזֶה־חָזִיתִי וַאֲסַפֵּרָה

107
00:12:32,540 --> 00:12:36,199
אֲשֶׁר־חֲכָמִים יַגִּידוּ וְלֹא כִחֲדוּ מֵאֲבוֹתָם

108
00:12:36,200 --> 00:13:12,999
לָהֶם לְבַדָּם נִתְּנָה הָאָרֶץ וְלֹא־עָבַר זָר בְּתוֹכָם

109
00:13:13,000 --> 00:13:14,459
כל ימי רשע

110
00:13:14,460 --> 00:13:26,659
כָּל־יְמֵי רָשָׁע הוּא מִתְחוֹלֵל וּמִסְפַּר שָׁנִים נִצְפְּנוּ לֶעָרִיץ

111
00:13:26,660 --> 00:13:29,539
קוֹל־פְּחָדִים בְּאָזְנָיו בַּשָּׁלוֹם שׁוֹדֵד יְבוֹאֶנּוּ

112
00:13:29,540 --> 00:13:39,319
לֹא־יַאֲמִין שׁוּב מִנִּי־חֹשֶׁךְ וְצָפוּ וְצָפוּי הוּא אֱלֵי־חָרֶב

113
00:13:39,320 --> 00:13:44,599
נֹדֵד הוּא לַלֶּחֶם אַיֵּה יָדַע כִּי־נָכוֹן בְּיָדוֹ יוֹם־חֹשֶׁךְ

114
00:13:44,600 --> 00:13:52,159
יְבַעֲתֻהוּ צַר וּמְצוּקָה תִּתְקְפֵהוּ כְּמֶלֶךְ עָתִיד לַכִּידוֹר

115
00:13:52,160 --> 00:14:02,679
כִּי־נָטָה אֶל־אֵל יָדוֹ וְאֶל־שַׁדַּי יִתְגַּבָּר

116
00:14:02,680 --> 00:14:05,359
יָרוּץ אֵלָיו בְּצַוָּאר בַּעֲבִי גַּבֵּי מָגִנָּיו

117
00:14:05,360 --> 00:14:13,019
כִּי־כִסָּה פָנָיו בְּחֶלְבּוֹ וַיַּעַשׂ פִּימָה עֲלֵי־כָסֶל

118
00:14:13,020 --> 00:14:21,199
וַיִּשְׁכּוֹן עָרִים נִכְחָדוֹת בָּתִּים לֹא־יֵשְׁבוּ לָמוֹ אֲשֶׁר הִתְעַתְּדוּ לְגַלִּים

119
00:14:21,200 --> 00:14:25,039
לֹא־יֶעְשַׁר וְלֹא־יָקוּם חֵילוֹ וְלֹא־יִטֶּה לָאָרֶץ מִנְלָם

120
00:14:25,040 --> 00:14:38,719
לֹא־יָסוּר מִנִּי־חֹשֶׁךְ יֹנַקְתּוֹ תְּיַבֵּשׁ שַׁלְהָבֶת וְיָסוּר בְּרוּחַ פִּיו

121
00:14:38,720 --> 00:14:43,299
אַל־יַאֲמֵן בַּשָּׁו נִתְעָה כִּי־שָׁוְא תִּהְיֶה תְמוּרָתוֹ

122
00:14:43,300 --> 00:14:45,999
בְּלֹא־יוֹמוֹ תִּמָּלֵא וְכִפָּתוֹ לֹא רַעֲנָנָה

123
00:14:46,000 --> 00:14:48,819
יַחְמֹס כַּגֶּפֶן בִּסְרוֹ וְיַשְׁלֵךְ כַּזַּיִת נִצָּתוֹ

124
00:14:48,820 --> 00:14:58,659
כִּי־עֲדַת חָנֵף גַּלְמוּד וְאֵשׁ אָכְלָה אָהֳלֵי־שֹׁחַד

125
00:14:58,660 --> 00:15:07,999
הָרֹה עָמָל וְיָלֹד אָוֶן וּבִטְנָם תָּכִין מִרְמָה

126
00:15:08,000 --> 00:15:09,559
מנחמי עמל

127
00:15:09,560 --> 00:15:13,799
וַיַּעַן אִיּוֹב וַיֹּאמַר

128
00:15:13,800 --> 00:15:20,099
שָׁמַעְתִּי כְאֵלֶּה רַבּוֹת מְנַחֲמֵי עָמָל כֻּלְּכֶם

129
00:15:20,100 --> 00:15:28,659
הֲקֵץ לְדִבְרֵי־רוּחַ אוֹ מַה־יַּמְרִיצְךָ כִּי תַעֲנֶה

130
00:15:28,660 --> 00:15:48,639
גַּם אָנֹכִי כָּכֶם אֲדַבֵּרָה לוּ יֵשׁ נַפְשְׁכֶם תַּחַת נַפְשִׁי אַחְבִּירָה עֲלֵיכֶם בְּמִלִּים וְאָנִיעָה עֲלֵיכֶם בְּמוֹ רֹאשִׁי

131
00:15:48,640 --> 00:15:51,219
אֲאַמִּצְכֶם בְּמוֹ־פִי וְנִיד שְׂפָתַי יַחְשֹׂךְ

132
00:15:51,220 --> 00:16:08,999
אִם־אֲדַבְּרָה לֹא־יֵחָשֵׂךְ כְּאֵבִי וְאַחְדְּלָה מַה־מִּנִּי יַהֲלֹךְ

133
00:16:09,000 --> 00:16:10,259
אך עתה הלאני

134
00:16:10,260 --> 00:16:16,779
אַךְ־עַתָּה הֶלְאָנִי הֲשִׁמּוֹתָ כָּל־עֲדָתִי

135
00:16:16,780 --> 00:16:23,979
וַתִּקְמְטֵנִי לְעֵד הָיָה וַיָּקָם בִּי כַחֲשִׁי בְּפָנַי יַעֲנֶה

136
00:16:23,980 --> 00:16:30,939
אַפּוֹ טָרַף וַיִּשְׂטְמֵנִי חָרַק עָלַי בְּשִׁנָּיו צָרִי יִלְטֹשׁ עֵינָיו לִי

137
00:16:30,940 --> 00:16:35,879
פָּעֲרוּ עָלַי בְּפִיהֶם בְּחֶרְפָּה הִכּוּ לְחָיָי יַחַד עָלַי יִתְמַלָּאוּן

138
00:16:35,880 --> 00:16:45,459
יַסְגִּירֵנִי אֵל אֶל עֲוִיל וְעַל־יְדֵי רְשָׁעִים יִרְטֵנִי

139
00:16:45,460 --> 00:16:56,779
שָׁלֵו הָיִיתִי וַיְפַרְפְּרֵנִי וְאָחַז בְּעָרְפִּי וַיְפַצְפְּצֵנִי וַיְקִימֵנִי לוֹ לְמַטָּרָה

140
00:16:56,780 --> 00:17:07,979
יָסֹבּוּ עָלַי רַבָּיו יְפַלַּח כִּלְיוֹתַי וְלֹא יַחְמֹל יִשְׁפֹּךְ לָאָרֶץ מְרֵרָתִי

141
00:17:07,980 --> 00:17:15,119
יִפְרְצֵנִי פֶרֶץ עַל־פְּנֵי־פָרֶץ יָרֻץ עָלַי כְּגִבּוֹר

142
00:17:15,120 --> 00:17:18,479
שַׂק תָּפַרְתִּי עֲלֵי גִלְדִּי וְעֹלַלְתִּי בֶעָפָר קַרְנִי

143
00:17:18,480 --> 00:17:23,119
פָּנַי חֳמַרְמְרֻה חֳמַרְמְרוּ מִנִּי־בֶכִי וְעַל עַפְעַפַּי צַלְמָוֶת

144
00:17:23,120 --> 00:17:34,999
עַל לֹא־חָמָס בְּכַפָּי וּתְפִלָּתִי זַכָּה

145
00:17:35,000 --> 00:17:36,439
ארץ אל תכסי דמי

146
00:17:36,440 --> 00:18:00,479
אֶרֶץ אַל־תְּכַסִּי דָמִי וְאַל־יְהִי מָקוֹם לְזַעֲקָתִי

147
00:18:00,480 --> 00:18:08,439
גַּם־עַתָּה הִנֵּה־בַשָּׁמַיִם עֵדִי וְשָׂהֲדִי בַּמְּרֹמִים

148
00:18:08,440 --> 00:18:14,059
מְלִיצַי רֵעָי אֶל־אֱלוֹהַּ דָּלְפָה עֵינִי

149
00:18:14,060 --> 00:18:17,659
וְיוֹכַח לְגֶבֶר עִם־אֱלוֹהַּ וּבֶן־אָדָם לְרֵעֵהוּ

150
00:18:17,660 --> 00:18:27,779
כִּי־שְׁנוֹת מִסְפָּר יֶאֱתָיוּ וְאֹרַח לֹא־אָשׁוּב אֶהֱלֹךְ

151
00:18:27,780 --> 00:18:34,819
רוּחִי חֻבָּלָה יָמַי נִזְעָכוּ קְבָרִים לִי

152
00:18:34,820 --> 00:18:41,999
אִם־לֹא הֲתֻלִים עִמָּדִי וּבְהַמְּרוֹתָם תָּלַן עֵינִי

153
00:18:42,000 --> 00:18:43,639
שימה נא ערבני

154
00:18:43,640 --> 00:18:58,119
שִׂימָה־נָּא עָרְבֵנִי עִמָּךְ מִי הוּא לְיָדִי יִתָּקֵעַ

155
00:18:58,120 --> 00:19:13,119
כִּי־לִבָּם צָפַנְתָּ מִשָּׂכֶל עַל־כֵּן לֹא תְרֹמֵם

156
00:19:13,120 --> 00:19:16,639
לְחֵלֶק יַגִּיד רֵעִים וְעֵינֵי בָנָיו תִּכְלֶנָה

157
00:19:16,640 --> 00:19:24,379
וְהִצִּיגַנִי לִמְשֹׁל עַמִּים וְתֹפֶת לְפָנִים אֶהְיֶה

158
00:19:24,380 --> 00:19:36,139
וַתֵּכַהּ מִכַּעַשׂ עֵינִי וִיצֻרַי כַּצֵּל כֻּלָּם

159
00:19:36,140 --> 00:19:46,560
יָשֹׁמּוּ יְשָׁרִים עַל־זֹאת וְנָקִי עַל־חָנֵף יִתְעֹרָר
