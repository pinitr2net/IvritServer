1
00:00:00,000 --> 00:00:02,999
סידרא ה' באיוב (כב, ל - כט, יג)

2
00:00:03,000 --> 00:00:10,399
אליפז מסיים ואיוב מבקש להישפט לפני ה'

3
00:00:10,400 --> 00:00:18,379
יְמַלֵּט אִי־נָקִי וְנִמְלַט בְּבֹר כַּפֶּיךָ

4
00:00:18,380 --> 00:00:19,399
וַיַּעַן אִיּוֹב וַיֹּאמַר

5
00:00:19,400 --> 00:00:29,459
גַּם־הַיּוֹם מְרִי שִׂחִי יָדִי כָּבְדָה עַל־אַנְחָתִי

6
00:00:29,460 --> 00:00:32,559
מִי־יִתֵּן יָדַעְתִּי וְאֶמְצָאֵהוּ אָבוֹא עַד־תְּכוּנָתוֹ

7
00:00:32,560 --> 00:00:37,399
אֶעֶרְכָה לְפָנָיו מִשְׁפָּט וּפִי אֲמַלֵּא תוֹכָחוֹת

8
00:00:37,400 --> 00:00:48,379
אֵדְעָה מִלִּים יַעֲנֵנִי וְאָבִינָה מַה־יֹּאמַר־לִי

9
00:00:48,380 --> 00:00:58,979
הַבְּרָב־כֹּחַ יָרִיב עִמָּדִי לֹא אַךְ־הוּא יָשִׂם בִּי

10
00:00:58,980 --> 00:01:05,999
שָׁם יָשָׁר נוֹכָח עִמּוֹ וַאֲפַלְּטָה לָנֶצַח מִשֹּׁפְטִי

11
00:01:06,000 --> 00:01:07,659
איוב מחפש את ה' ומחזיק בצדקתו

12
00:01:07,660 --> 00:01:17,259
הֵן קֶדֶם אֶהֱלֹךְ וְאֵינֶנּוּ וְאָחוֹר וְלֹא־אָבִין לוֹ

13
00:01:17,260 --> 00:01:21,839
שְׂמֹאול בַּעֲשֹׂתוֹ וְלֹא־אָחַז יַעְטֹף יָמִין וְלֹא אֶרְאֶה

14
00:01:21,840 --> 00:01:29,179
כִּי־יָדַע דֶּרֶךְ עִמָּדִי בְּחָנַנִי כַּזָּהָב אֵצֵא

15
00:01:29,180 --> 00:01:41,119
בַּאֲשֻׁרוֹ אָחֲזָה רַגְלִי דַּרְכּוֹ שָׁמַרְתִּי וְלֹא־אָט

16
00:01:41,120 --> 00:01:52,399
מִצְוַת שְׂפָתָיו וְלֹא אָמִישׁ מֵחֻקִּי צָפַנְתִּי אִמְרֵי־פִיו

17
00:01:52,400 --> 00:01:56,439
וְהוּא בְאֶחָד וּמִי יְשִׁיבֶנּוּ וְנַפְשׁוֹ אִוְּתָה וַיָּעַשׂ

18
00:01:56,440 --> 00:02:01,499
כִּי יַשְׁלִים חֻקִּי וְכָהֵנָּה רַבּוֹת עִמּוֹ

19
00:02:01,500 --> 00:02:04,779
עַל־כֵּן מִפָּנָיו אֶבָּהֵל אֶתְבּוֹנֵן וְאֶפְחַד מִמֶּנּוּ

20
00:02:04,780 --> 00:02:17,319
וְאֵל הֵרַךְ לִבִּי וְשַׁדַּי הִבְהִילָנִי

21
00:02:17,320 --> 00:02:24,999
כִּי־לֹא נִצְמַתִּי מִפְּנֵי־חֹשֶׁךְ וּמִפָּנַי כִּסָּה־אֹפֶל

22
00:02:25,000 --> 00:02:26,419
מדוע הרשעים מצליחים

23
00:02:26,420 --> 00:02:35,599
מַדּוּעַ מִשַּׁדַּי לֹא־נִצְפְּנוּ עִתִּים וְיֹדְעָו וְיֹדְעָיו לֹא־חָזוּ יָמָיו

24
00:02:35,600 --> 00:02:41,299
גְּבֻלוֹת יַשִּׂיגוּ עֵדֶר גָּזְלוּ וַיִּרְעוּ

25
00:02:41,300 --> 00:02:46,299
חֲמוֹר יְתוֹמִים יִנְהָגוּ יַחְבְּלוּ שׁוֹר אַלְמָנָה

26
00:02:46,300 --> 00:02:56,019
יַטּוּ אֶבְיֹנִים מִדָּרֶךְ יַחַד חֻבְּאוּ עֲנִיֵּי־אָרֶץ

27
00:02:56,020 --> 00:03:09,099
הֵן פְּרָאִים בַּמִּדְבָּר יָצְאוּ בְּפָעֳלָם מְשַׁחֲרֵי לַטָּרֶף עֲרָבָה לוֹ לֶחֶם לַנְּעָרִים

28
00:03:09,100 --> 00:03:14,239
בַּשָּׂדֶה בְּלִילוֹ יִקְצֹירוּ יִקְצוֹרוּ וְכֶרֶם רָשָׁע יְלַקֵּשׁוּ

29
00:03:14,240 --> 00:03:26,719
עָרוֹם יָלִינוּ מִבְּלִי לְבוּשׁ וְאֵין כְּסוּת בַּקָּרָה

30
00:03:26,720 --> 00:03:36,659
מִזֶּרֶם הָרִים יִרְטָבוּ וּמִבְּלִי מַחְסֶה חִבְּקוּ־צוּר

31
00:03:36,660 --> 00:03:49,959
יִגְזְלוּ מִשֹּׁד יָתוֹם וְעַל־עָנִי יַחְבֹּלוּ

32
00:03:49,960 --> 00:03:52,859
עָרוֹם הִלְּכוּ בְּלִי לְבוּשׁ וּרְעֵבִים נָשְׂאוּ עֹמֶר

33
00:03:52,860 --> 00:04:07,619
בֵּין־שׁוּרֹתָם יַצְהִירוּ יְקָבִים דָּרְכוּ וַיִּצְמָאוּ

34
00:04:07,620 --> 00:04:23,599
מֵעִיר מְתִים יִנְאָקוּ וְנֶפֶשׁ־חֲלָלִים תְּשַׁוֵּעַ וֶאֱלוֹהַּ לֹא־יָשִׂים תִּפְלָה

35
00:04:23,600 --> 00:04:33,739
הֵמָּה הָיוּ בְּמֹרְדֵי אוֹר לֹא־הִכִּירוּ דְרָכָיו וְלֹא יָשְׁבוּ בִּנְתִיבֹתָיו

36
00:04:33,740 --> 00:04:39,699
לָאוֹר יָקוּם רוֹצֵחַ יִקְטָל־עָנִי וְאֶבְיוֹן וּבַלַּיְלָה יְהִי כַגַּנָּב

37
00:04:39,700 --> 00:04:48,259
וְעֵין נֹאֵף שָׁמְרָה נֶשֶׁף לֵאמֹר לֹא־תְשׁוּרֵנִי עָיִן וְסֵתֶר פָּנִים יָשִׂים

38
00:04:48,260 --> 00:04:59,979
חָתַר בַּחֹשֶׁךְ בָּתִּים יוֹמָם חִתְּמוּ־לָמוֹ לֹא־יָדְעוּ אוֹר

39
00:04:59,980 --> 00:05:09,219
כִּי יַחְדָּו בֹּקֶר לָמוֹ צַלְמָוֶת כִּי־יַכִּיר בַּלְהוֹת צַלְמָוֶת

40
00:05:09,220 --> 00:05:16,099
קַל־הוּא עַל־פְּנֵי־מַיִם תְּקֻלַּל חֶלְקָתָם בָּאָרֶץ לֹא־יִפְנֶה דֶּרֶךְ כְּרָמִים

41
00:05:16,100 --> 00:05:28,559
צִיָּה גַם־חֹם יִגְזְלוּ מֵימֵי־שֶׁלֶג שְׁאוֹל חָטָאוּ

42
00:05:28,560 --> 00:05:37,659
יִשְׁכָּחֵהוּ רֶחֶם מְתָקוֹ רִמָּה עוֹד לֹא־יִזָּכֵר וַתִּשָּׁבֵר כָּעֵץ עַוְלָה

43
00:05:37,660 --> 00:05:49,439
רֹעֶה עֲקָרָה לֹא תֵלֵד וְאַלְמָנָה לֹא יְיֵטִיב

44
00:05:49,440 --> 00:06:07,019
וּמָשַׁךְ אַבִּירִים בְּכֹחוֹ יָקוּם וְלֹא־יַאֲמִין בַּחַיִּין

45
00:06:07,020 --> 00:06:13,839
יִתֶּן־לוֹ לָבֶטַח וְיִשָּׁעֵן וְעֵינֵיהוּ עַל־דַּרְכֵיהֶם

46
00:06:13,840 --> 00:06:32,139
רוֹמּוּ מְּעַט וְאֵינֶנּוּ וְהֻמְּכוּ כַּכֹּל יִקָּפְצוּן וּכְרֹאשׁ שִׁבֹּלֶת יִמָּלוּ

47
00:06:32,140 --> 00:07:01,999
וְאִם־לֹא אֵפוֹ מִי יַכְזִיבֵנִי וְיָשֵׂם לְאַל מִלָּתִי

48
00:07:02,000 --> 00:07:03,919
בלדד: מול גדלות ה' אין אדם צודק

49
00:07:03,920 --> 00:07:13,279
וַיַּעַן בִּלְדַּד הַשֻּׁחִי וַיֹּאמַר

50
00:07:13,280 --> 00:07:18,499
הַמְשֵׁל וָפַחַד עִמּוֹ עֹשֶׂה שָׁלוֹם בִּמְרוֹמָיו

51
00:07:18,500 --> 00:07:30,979
הֲיֵשׁ מִסְפָּר לִגְדוּדָיו וְעַל־מִי לֹא־יָקוּם אוֹרֵהוּ

52
00:07:30,980 --> 00:07:39,819
וּמַה־יִּצְדַּק אֱנוֹשׁ עִם־אֵל וּמַה־יִּזְכֶּה יְלוּד אִשָּׁה

53
00:07:39,820 --> 00:07:43,039
הֵן עַד־יָרֵחַ וְלֹא יַאֲהִיל וְכוֹכָבִים לֹא־זַכּוּ בְעֵינָיו

54
00:07:43,040 --> 00:07:55,999
אַף כִּי־אֱנוֹשׁ רִמָּה וּבֶן־אָדָם תּוֹלֵעָה

55
00:07:56,000 --> 00:07:57,159
איוב: גם אני יודע את גדלות ה'

56
00:07:57,160 --> 00:07:58,579
וַיַּעַן אִיּוֹב וַיֹּאמַר

57
00:07:58,580 --> 00:08:01,039
מֶה־עָזַרְתָּ לְלֹא־כֹחַ הוֹשַׁעְתָּ זְרוֹעַ לֹא־עֹז

58
00:08:01,040 --> 00:08:03,739
מַה־יָּעַצְתָּ לְלֹא חָכְמָה וְתֻשִׁיָּה לָרֹב הוֹדָעְתָּ

59
00:08:03,740 --> 00:08:25,859
אֶת־מִי הִגַּדְתָּ מִלִּין וְנִשְׁמַת־מִי יָצְאָה מִמֶּךָּ

60
00:08:25,860 --> 00:08:29,039
הָרְפָאִים יְחוֹלָלוּ מִתַּחַת מַיִם וְשֹׁכְנֵיהֶם

61
00:08:29,040 --> 00:08:31,399
עָרוֹם שְׁאוֹל נֶגְדּוֹ וְאֵין כְּסוּת לָאֲבַדּוֹן

62
00:08:31,400 --> 00:08:40,759
נֹטֶה צָפוֹן עַל־תֹּהוּ תֹּלֶה אֶרֶץ עַל־בְּלִי־מָה

63
00:08:40,760 --> 00:08:43,899
צֹרֵר־מַיִם בְּעָבָיו וְלֹא־נִבְקַע עָנָן תַּחְתָּם

64
00:08:43,900 --> 00:08:50,379
מְאַחֵז פְּנֵי־כִסֵּה פַּרְשֵׁז עָלָיו עֲנָנוֹ

65
00:08:50,380 --> 00:08:53,599
חֹק־חָג עַל־פְּנֵי־מָיִם עַד־תַּכְלִית אוֹר עִם־חֹשֶׁךְ

66
00:08:53,600 --> 00:08:56,199
עַמּוּדֵי שָׁמַיִם יְרוֹפָפוּ וְיִתְמְהוּ מִגַּעֲרָתוֹ

67
00:08:56,200 --> 00:09:00,919
בְּכֹחוֹ רָגַע הַיָּם וּבִתְובֻנָתוֹ וּבִתְבוּנָתוֹ מָחַץ רָהַב

68
00:09:00,920 --> 00:09:16,079
בְּרוּחוֹ שָׁמַיִם שִׁפְרָה חֹלֲלָה יָדוֹ נָחָשׁ בָּרִחַ

69
00:09:16,080 --> 00:09:26,999
הֶן־אֵלֶּה קְצוֹת דְּרָכָו וּמַה־שֵּׁמֶץ דָּבָר נִשְׁמַע־בּוֹ וְרַעַם גְּבוּרֹתָו גְּבוּרֹתָיו מִי יִתְבּוֹנָן

70
00:09:27,000 --> 00:09:28,979
איוב נשבע על צדקתו

71
00:09:28,980 --> 00:09:30,199
וַיֹּסֶף אִיּוֹב שְׂאֵת מְשָׁלוֹ וַיֹּאמַר

72
00:09:30,200 --> 00:10:11,439
חַי־אֵל הֵסִיר מִשְׁפָּטִי וְשַׁדַּי הֵמַר נַפְשִׁי

73
00:10:11,440 --> 00:10:13,779
כִּי־כָל־עוֹד נִשְׁמָתִי בִי וְרוּחַ אֱלוֹהַּ בְּאַפִּי

74
00:10:13,780 --> 00:10:17,459
אִם־תְּדַבֵּרְנָה שְׂפָתַי עַוְלָה וּלְשׁוֹנִי אִם־יֶהְגֶּה רְמִיָּה

75
00:10:17,460 --> 00:10:32,119
חָלִילָה לִּי אִם־אַצְדִּיק אֶתְכֶם עַד־אֶגְוָע לֹא־אָסִיר תֻּמָּתִי מִמֶּנִּי

76
00:10:32,120 --> 00:10:36,999
בְּצִדְקָתִי הֶחֱזַקְתִּי וְלֹא אַרְפֶּהָ לֹא־יֶחֱרַף לְבָבִי מִיָּמָי

77
00:10:37,000 --> 00:10:38,739
גורל החנף והרשע

78
00:10:38,740 --> 00:10:49,039
יְהִי כְרָשָׁע אֹיְבִי וּמִתְקוֹמֲמִי כְעַוָּל

79
00:10:49,040 --> 00:10:59,379
כִּי מַה־תִּקְוַת חָנֵף כִּי יִבְצָע כִּי יֵשֶׁל אֱלוֹהַּ נַפְשׁוֹ

80
00:10:59,380 --> 00:11:03,879
הֲצַעֲקָתוֹ יִשְׁמַע אֵל כִּי־תָבוֹא עָלָיו צָרָה

81
00:11:03,880 --> 00:11:10,539
אִם־עַל־שַׁדַּי יִתְעַנָּג יִקְרָא אֱלוֹהַּ בְּכָל־עֵת

82
00:11:10,540 --> 00:11:13,659
אוֹרֶה אֶתְכֶם בְּיַד־אֵל אֲשֶׁר עִם־שַׁדַּי לֹא אֲכַחֵד

83
00:11:13,660 --> 00:11:23,899
הֵן־אַתֶּם כֻּלְּכֶם חֲזִיתֶם וְלָמָּה־זֶּה הֶבֶל תֶּהְבָּלוּ

84
